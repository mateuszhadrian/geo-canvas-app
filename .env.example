# GeoCanvas — przykładowe zmienne środowiskowe
# Skopiuj ten plik jako .env.local i uzupełnij wartościami
# NIE commituj .env.local — jest w .gitignore

# ── Przyszłe zmienne Supabase ──────────────────────────────────────────────────
# Potrzebne gdy zostanie dodany backend Supabase (patrz .ai/tech-stack.md)
# Pobierz z: Supabase Dashboard → Project Settings → API

# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # TYLKO serwer — NIGDY NEXT_PUBLIC!

# ── Lokalne overridy deweloperskie ─────────────────────────────────────────────
# NODE_ENV=development
